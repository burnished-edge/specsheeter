<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Link CAD" Width="450" Height="500" WindowStartupLocation="CenterScreen"
        Background="#F5F5F5" FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. File Selection -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="1. Select CAD Files" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <Button Content="Browse Files..." x:Name="browse_btn" Click="browse_files" Padding="5" Background="White"/>
            <TextBlock x:Name="file_count_tb" Text="0 files selected." Margin="0,5,0,0" FontStyle="Italic" Foreground="Gray"/>
        </StackPanel>

        <!-- 2. Sheet Naming -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="2. Sheet Naming (Optional)" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Prefix:"/>
                    <TextBox x:Name="prefix_tb" Text="" Padding="2"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Suffix:"/>
                    <TextBox x:Name="suffix_tb" Text="" Padding="2"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- 3. Scale -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Text="3. CAD Import Scale" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <TextBlock Text="1.0 = Full Size (Auto-detects units). Decimals force Custom Units." TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,5"/>
            <TextBox x:Name="scale_tb" Text="1.0" Padding="2" Width="100" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- 4. Match Parameters -->
        <StackPanel Grid.Row="3" Margin="0,0,0,20">
            <TextBlock Text="4. Match Sheet Properties" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <TextBlock Text="Select a template sheet to copy organization parameters (Use, Discipline, etc.):" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <ComboBox x:Name="sheet_cb" Padding="4"/>
        </StackPanel>

        <!-- Action Buttons -->
        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancel" x:Name="cancel_btn" Click="cancel_clicked" Padding="10" Background="White"/>
            <Button Grid.Column="2" Content="Continue to Placement" x:Name="ok_btn" Click="ok_clicked" Padding="10" Background="#0078D7" Foreground="White" FontWeight="Bold"/>
        </Grid>
    </Grid>
</Window>